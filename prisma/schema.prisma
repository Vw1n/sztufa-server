generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id              String    @id @default(cuid())
  teamName        String    @unique
  teamDoctor      String?
  headCoach       String?
  teamLeader      String?
  coachPhone      String?
  leaderPhone     String?
  homeJerseyColor String
  awayJerseyColor String
  teamLogo        String?
  homeJersey      String?
  awayJersey      String?
  gender          String    @default("MALE") // MALE: 男子, FEMALE: 女子
  players         Player[]
  homeMatches     Match[]   @relation("HomeTeam")
  awayMatches     Match[]   @relation("AwayTeam")
  users           User[]
  deletedAt       DateTime?
  seasonPlayers   SeasonTeamPlayer[]
  groupTeams      SeasonGroupTeam[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teamName])
  @@index([deletedAt])
}

model Player {
  id                  String  @id @default(cuid())
  name                String
  studentId           String  @unique
  jerseyNumber        String
  photo               String?
  status              String  @default("active")
  yellowCards         Int     @default(0)
  redCards            Int     @default(0)
  suspendedAtMatchId  String?
  teamId              String
  team                Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  goals               Goal[]
  events              MatchEvent[] @relation("EventPlayer")
  subEvents           MatchEvent[] @relation("EventSubPlayer")
  assistEvents        MatchEvent[] @relation("EventAssistPlayer")
  mvpMatches          Match[]      @relation("MatchMvpPlayer")
  deletedAt           DateTime?
  seasonPlayers       SeasonTeamPlayer[]
  matchLineups        MatchLineup[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([teamId])
  @@index([studentId])
  @@index([deletedAt])
  @@index([teamId, deletedAt])
}

model Match {
  id              String        @id @default(cuid())
  homeTeamId      String
  awayTeamId      String
  homeTeam        Team          @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam        Team          @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  homeScore       Int           @default(0)
  awayScore       Int           @default(0)
  homePenaltyScore Int?
  awayPenaltyScore Int?
  winnerTeamId    String?
  decidedBy       String?
  matchDate       DateTime
  location        String
  status          String        @default("scheduled")
  goals           Goal[]
  events          MatchEvent[]
  seasonId        String?
  season          Season?       @relation(fields: [seasonId], references: [id])
  mvpPlayerId     String?
  mvpPlayer       Player?       @relation("MatchMvpPlayer", fields: [mvpPlayerId], references: [id])
  mvpPlayerName   String?
  lineups         MatchLineup[]
  stage           String        @default("LEAGUE") // LEAGUE, GROUP, KNOCKOUT
  groupName       String?
  knockoutRound   String?
  knockoutMatchIndex Int?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([matchDate])
  @@index([seasonId, deletedAt])
  @@index([seasonId, stage, deletedAt])
  @@index([mvpPlayerId])
  @@index([deletedAt])
}

model Goal {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId     String?
  player       Player?  @relation(fields: [playerId], references: [id])
  playerName   String
  jerseyNumber String
  goalTime     String
  teamType     String
  createdAt    DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
}

model MatchEvent {
  id                 String   @id @default(cuid())
  matchId            String
  match              Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  eventTime          String
  eventType          String
  phase              String   @default("REGULAR")
  shootoutRound      Int?
  shootoutOrder      Int?
  playerId           String?
  player             Player?  @relation("EventPlayer", fields: [playerId], references: [id])
  playerName         String?
  jerseyNumber       String?
  subPlayerId        String?
  subPlayer          Player?  @relation("EventSubPlayer", fields: [subPlayerId], references: [id])
  subPlayerName      String?
  subJerseyNumber    String?
  assistPlayerId     String?
  assistPlayer       Player?  @relation("EventAssistPlayer", fields: [assistPlayerId], references: [id])
  assistPlayerName   String?
  assistJerseyNumber String?
  description        String
  teamType           String
  createdAt          DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
  @@index([subPlayerId])
  @@index([assistPlayerId])
  @@index([matchId, eventTime])
  @@index([matchId, phase, shootoutOrder])
}

model News {
  id           String   @id @default(cuid())
  title        String
  category     String
  content      String   @default("")
  description  String   @default("")
  coverImage   String?
  wechatUrl    String?
  isPinned     Boolean  @default(false)
  viewCount    Int      @default(0)
  published    Boolean  @default(true)
  publishedAt  DateTime @default(now())
  date         String   @default("") // 格式如 "2026-06-10"
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([publishedAt])
  @@index([deletedAt])
}


model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  seasonDeletionApprovals SeasonDeletionApproval[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([teamId])
}

model AuditLog {
  id        String   @id @default(cuid())
  username  String
  action    String
  details   String
  createdAt DateTime @default(now())

  @@index([username])
  @@index([createdAt])
}

model Season {
  id             String   @id @default(cuid())
  name           String   @unique
  status         String   @default("active") // active, archived
  type           String   @default("LEAGUE") // LEAGUE, CUP
  matches        Match[]
  standingsCache Json?
  statsCache     Json?
  teamPlayers    SeasonTeamPlayer[]
  groupTeams     SeasonGroupTeam[]
  deletionApprovals SeasonDeletionApproval[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SeasonDeletionApproval {
  id         String   @id @default(cuid())
  seasonId   String
  approverId String
  season     Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  approver   User     @relation(fields: [approverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([seasonId, approverId])
  @@index([seasonId])
  @@index([approverId])
}

model SeasonTeamPlayer {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String
  playerId  String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([seasonId, playerId])
  @@index([seasonId])
  @@index([teamId])
  @@index([playerId])
}

model MatchLineup {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  teamType   String   // "home" | "away"
  lineupType String   // "starting" | "substitute"

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
}

model SeasonGroupTeam {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String
  groupName String   // e.g. "A", "B", "C", "D"
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([teamId])
}
