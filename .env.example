# Application
NODE_ENV=development
PORT=3001

# Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sztu_fa?schema=public"

# Local authentication
JWT_SECRET="local-development-secret-change-me"
JWT_EXPIRES_IN="7d"

# Cloudflare R2
# 本地不测试上传时可以暂时留空
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Backup cron
CRON_SECRET="local-cron-secret"

# Allowed frontend origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3002"