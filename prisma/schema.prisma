generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Team {
  id              String    @id @default(cuid())
  teamName        String    @unique
  teamDoctor      String?
  headCoach       String?
  teamLeader      String?
  coachPhone      String?
  leaderPhone     String?
  homeJerseyColor String
  awayJerseyColor String
  teamLogo        String?
  homeJersey      String?
  awayJersey      String?
  players         Player[]
  homeMatches     Match[]   @relation("HomeTeam")
  awayMatches     Match[]   @relation("AwayTeam")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teamName])
}

model Player {
  id            String  @id @default(cuid())
  name          String
  studentId     String  @unique
  jerseyNumber  String
  photo         String?
  teamId        String
  team          Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  goals         Goal[]
  events        MatchEvent[] @relation("EventPlayer")
  subEvents     MatchEvent[] @relation("EventSubPlayer")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teamId])
  @@index([studentId])
}

model Match {
  id              String        @id @default(cuid())
  homeTeamId      String
  awayTeamId      String
  homeTeam        Team          @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam        Team          @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  homeScore       Int           @default(0)
  awayScore       Int           @default(0)
  matchDate       DateTime
  location        String
  status          String        @default("scheduled")
  goals           Goal[]
  events          MatchEvent[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([matchDate])
}

model Goal {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId     String?
  player       Player?  @relation(fields: [playerId], references: [id])
  playerName   String
  jerseyNumber String
  goalTime     String
  teamType     String
  createdAt    DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
}

model MatchEvent {
  id              String   @id @default(cuid())
  matchId         String
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  eventTime       String
  eventType       String
  playerId        String?
  player          Player?  @relation("EventPlayer", fields: [playerId], references: [id])
  playerName      String?
  jerseyNumber    String?
  subPlayerId     String?
  subPlayer       Player?  @relation("EventSubPlayer", fields: [subPlayerId], references: [id])
  subPlayerName   String?
  subJerseyNumber String?
  description     String
  teamType        String
  createdAt       DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
  @@index([subPlayerId])
}

model News {
  id           String   @id @default(cuid())
  title        String
  category     String
  content      String
  coverImage   String?
  isPinned     Boolean  @default(false)
  viewCount    Int      @default(0)
  published    Boolean  @default(true)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([publishedAt])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
}
